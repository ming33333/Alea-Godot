[node name="DiceSoundOption" type="OptionButton" parent="Margin/VBox"]
unique_name_in_owner = true
layout_mode = 2

[node name="SteamNote" type="Label" parent="Margin/VBox"]
layout_mode = 2
autowrap_mode = 3
