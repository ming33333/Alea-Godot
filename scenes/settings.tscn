[connection signal="value_changed" from="Margin/VBox/VolumeSlider" to="." method="_on_volume_changed"]
[connection signal="item_selected" from="Margin/VBox/DiceSoundOption" to="." method="_on_dice_sound_selected"]
[connection signal="pressed" from="Margin/VBox/CheatRow/CheatApply" to="." method="_on_cheat_apply_pressed"]
[connection signal="pressed" from="Margin/VBox/CheatLock" to="." method="_on_cheat_lock_pressed"]
[connection signal="text_submitted" from="Margin/VBox/CheatRow/CheatCodeInput" to="." method="_on_cheat_code_submitted"]
[connection signal="pressed" from="Margin/VBox/Back" to="." method="_on_back"]
